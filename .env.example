# Supabase Configuration
# Copy this file to .env.local and fill in real values from Supabase Dashboard > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional server-only aliases used by some scripts/services
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Configuration (Resend)
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=TeamPulse <noreply@example.com>
SUPPORT_EMAIL=support@example.com

# Legacy URLs (if needed)
INVITE_ACCEPT_URL_BASE=https://example.com/app/routes/accept-invite.php
PASSWORD_RESET_URL_BASE=https://example.com/password/reset-password.php
EMAIL_VERIFICATION_URL_BASE=https://example.com/verify-email.php
